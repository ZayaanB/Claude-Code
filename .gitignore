# Claude Code - Sensitive Data
.env
*.env
*.credentials
*.secret
*.key

# Do not commit API keys or tokens
NVIDIA_NIM_API_KEY=
CLAUDE_API_KEY=

# Ignore large files and notes (keep config portable)
*.pdf
*.txt
*.md
!CLAUDE.md
!docs/**/*.md
!config/memory/**/*.md
!config/zayaan_guide.md
!config/mcp-guide.md
!MEMORY.md

# Ignore project-specific files

*.ipynb
.ipynb_checkpoints/

# Ignore IDE
.idea/
.vscode/
*.swp
*.swo

# Ignore Python cache
__pycache__/
*.pyc
*.pyo
.mypy_cache/
.pytest_cache/

# Ignore OS files
.DS_Store
Thumbs.db
